# ---- WordPress + WooCommerce (headless CMS + store) ----
# Your WordPress site URL (no trailing slash). The storefront queries
# <NEXT_PUBLIC_WP_URL>/graphql via WPGraphQL. When set, it reads live content
# (products, posts, artists, exhibitions) instead of the built-in demo data.
NEXT_PUBLIC_WP_URL=https://cms.uchaanarts.com

# WooCommerce store URL for headless checkout handoff (usually the same site).
NEXT_PUBLIC_WOO_URL=https://cms.uchaanarts.com

# Optional: hostname that serves WordPress media, for next/image optimization.
# (Set this if your images are on a different domain/CDN than NEXT_PUBLIC_WP_URL.)
WP_IMAGE_HOST=cms.uchaanarts.com

# ---- Customer accounts (login/register) ----
# WordPress plugin "JWT Authentication for WP-API" must be active, with
# JWT_AUTH_SECRET_KEY defined in wp-config.php.
# WooCommerce REST keys (read/write) power registration + order history:
# WooCommerce -> Settings -> Advanced -> REST API -> Add key
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=

# ---- Google Sign-In (Sign in with Google button on /login) ----
# Create an OAuth 2.0 Web client at https://console.cloud.google.com/apis/credentials
# Add your site's origin (e.g. https://uchaanarts.netlify.app) to "Authorized JavaScript origins".
# The public ID is used by the browser button; the server env verifies the token.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
